# Azure Power BI API Configuration
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกข้อมูลจริง

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Azure AD Credentials
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# สำหรับ Managed Identity (ถ้าใช้บน Azure VM/App Service)
# AZURE_CLIENT_ID=managed-identity-client-id
# IDENTITY_ENDPOINT=http://169.254.169.254/metadata/identity/oauth2/token

# PostgreSQL (production บน Docker server)
DATABASE_URL=postgresql://webchat:YOUR_PASSWORD@postgres:5432/webchat
POSTGRES_PASSWORD=YOUR_PASSWORD

# สำหรับ Development
# POWERBI_DEBUG=true
# TOKEN_CACHE_FILE=token_cache.json
